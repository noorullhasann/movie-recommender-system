{
  "buildCommand": "npm install && npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://movie-recommender-backend.onrender.com/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "VITE_API_URL": {
      "description": "Backend API URL",
      "example": "https://movie-recommender-backend.onrender.com"
    }
  },
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  }
}
